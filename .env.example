# ============================================================
# GopherAI 环境变量模板
# 复制为 .env.local 并填入真实值后使用
# ============================================================

# --- AI 模型（OpenAI / DeepSeek 兼容接口） ---
export OPENAI_API_KEY=sk-your-api-key-here
export OPENAI_MODEL_NAME=deepseek-chat
export OPENAI_BASE_URL=https://api.deepseek.com/v1

# --- 会话标题生成（智谱 GLM-4-Flash，免费） ---
# 注册地址：https://open.bigmodel.cn/
export TITLE_API_KEY=your-zhipu-api-key
export TITLE_MODEL_NAME=glm-4-flash
export TITLE_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- RAG 向量嵌入（火山引擎/豆包） ---
export RAG_EMBEDDING_API_KEY=ark-your-ark-key-here
